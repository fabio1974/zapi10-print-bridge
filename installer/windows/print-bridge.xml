<?xml version="1.0" encoding="UTF-8"?>
<service>
    <id>zapi10-print-bridge</id>
    <name>Zapi10 Print Bridge</name>
    <description>Bridge TCP/9100 para impressora ESC/POS via spooler do Windows. Permite que o app Zapi10 imprima na impressora local.</description>

    <executable>%BASE%\jre\bin\javaw.exe</executable>
    <arguments>-jar "%BASE%\print-bridge.jar"</arguments>

    <workingdirectory>%BASE%</workingdirectory>

    <onfailure action="restart" delay="10 sec"/>
    <onfailure action="restart" delay="30 sec"/>
    <onfailure action="restart" delay="1 min"/>

    <log mode="roll-by-size">
        <sizeThreshold>10240</sizeThreshold>
        <keepFiles>5</keepFiles>
    </log>

    <env name="PRINT_BRIDGE_PORT" value="9100"/>
    <env name="PRINT_BRIDGE_LOG_DIR" value="%BASE%\logs"/>

    <startmode>Automatic</startmode>
    <delayedAutoStart>false</delayedAutoStart>
</service>
